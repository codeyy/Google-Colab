        "\n",
        "start_date = \"2021-01-01\"\n",
        "end_date = \"2021-12-31\"\n",
        "\n",
        "# 1. Setup the Open-Meteo API client with a cache and retry mechanism\n",
        "cache_session = requests_cache.CachedSession('.cache', expire_after=3600)\n",
        "retry_session = retry(cache_session, retries=5, backoff_factor=0.2)\n",
        "openmeteo = openmeteo_requests.Client(session=retry_session)\n",
        "\n",
        "# 2. Define the historical API endpoint and configuration parameters\n",
        "url = \"https://archive-api.open-meteo.com/v1/archive/\"\n",
        "params = {\n",
        "    \"latitude\": 51.5074,\n",
        "    \"longitude\": -0.1278,\n",
        "    \"start_date\": start_date,\n",
        "    \"end_date\": end_date,\n",
        "    \"hourly\": [\"temperature_2m\", \"relative_humidity_2m\", \"wind_speed_10m\"]\n",
        "}\n",
        "\n",
        "# 3. Request data\n",
        "responses = openmeteo.weather_api(url, params=params)\n",
        "\n",
        "# 4. Process the first location's data response\n",
        "response = responses[0]\n",
        "print(f\"Coordinates: {response.Latitude()}°N, {response.Longitude()}°E\")\n",
        "\n",
        "# 5. Extract and parse the hourly variables\n",
        "hourly = response.Hourly()\n",
        "\n",
        "hourly_temperature_2m = hourly.Variables(0).ValuesAsNumpy()\n",
        "hourly_relative_humidity_2m = hourly.Variables(1).ValuesAsNumpy()\n",
        "hourly_wind_speed_10m = hourly.Variables(2).ValuesAsNumpy()\n",
        "\n",
        "# 6. Create a timestamp range matching the data length\n",
        "hourly_data = {\n",
        "    \"date\": pd.date_range(\n",
        "        start=pd.to_datetime(hourly.Time(), unit=\"s\", utc=True),\n",
        "        end=pd.to_datetime(hourly.TimeEnd(), unit=\"s\", utc=True),\n",
        "        freq=pd.Timedelta(seconds=hourly.Interval()),\n",
        "        inclusive=\"left\"\n",
        "    ),\n",
        "    \"temperature_2m\": hourly_temperature_2m,\n",
        "    \"humidity_2m\": hourly_relative_humidity_2m,\n",
        "    \"wind_speed_10m\": hourly_wind_speed_10m,\n",
        "}\n",
        "\n",
        "# 7. Convert to DataFrame\n",
        "df = pd.DataFrame(data=hourly_data)\n",
        "\n",
        "\n",
        "corr_matrix = df.corr()\n",
        "print(corr_matrix)\n",
        "\n",
        "\n",
        "plt.figure(figsize=(10, 8))\n",
        "sns.heatmap(corr_matrix, annot=True, cmap='coolwarm', vmin=-1, vmax=1)\n",
        "plt.title(\"Correlation Matrix Heatmap\")\n",
        "plt.show()\n",
        "\n",
        "import sys\n",
        "sys.exit()\n",
        "\n",
        "# 1. Prepare data and calculate moving average\n",
        "# 1. Prepare data and calculate a cleaner 5-day (120-hour) moving average\n",
        "df[\"time\"] = pd.to_datetime(df[\"date\"])\n",
        "df[\"moving_avg\"] = df[\"temperature_2m\"].rolling(window=(24*5), min_periods=1).mean()\n",
        "\n",
        "# 2. Setup the plot canvas\n",
        "sns.set_theme(style=\"white\") # Switch to clean white to manually control grid contrast\n",
        "fig, ax = plt.subplots(figsize=(15, 7), dpi=120)\n",
        "\n",
        "# 3. Plot individual scatter dots (Shrunk to s=3 and given light alpha to handle density)\n",
        "sns.scatterplot(\n",
        "    data=df,\n",
        "    x=\"time\",\n",
        "    y=\"temperature_2m\",\n",
        "    color=\"red\",\n",
        "    s=40,\n",
        "    alpha=0.15,\n",
        "    label=\"Actual Reading (Hourly)\",\n",
        "    ax=ax,\n",
        "    zorder=2,\n",
        ")\n",
        "sns.scatterplot(\n",
        "    data=df,\n",
        "    x=\"time\",\n",
        "    y=\"humidity_2m\",\n",
        "    color=\"green\",\n",
        "    s=40,\n",
        "    alpha=0.15,\n",
        "    label=\"Actual Reading (Hourly)\",\n",
        "    ax=ax,\n",
        "    zorder=2,\n",
        ")\n",
        "sns.scatterplot(\n",
        "    data=df,\n",
        "    x=\"time\",\n",
        "    y=\"wind_speed_10m\",\n",
        "    color=\"blue\",\n",
        "    s=40,\n",
        "    alpha=0.15,\n",
        "    label=\"Actual Reading (Hourly)\",\n",
        "    ax=ax,\n",
        "    zorder=2,\n",
        ")\n",
        "\n",
        "# 4. Plot moving average line (Thickened to cut through the background cluster)\n",
        "sns.lineplot(\n",
        "    data=df,\n",
        "    x=\"time\",\n",
        "    y=\"moving_avg\",\n",
        "    color=\"darkblue\",\n",
        "    linewidth=3,\n",
        "    label=\"5-Day Moving Average\",\n",
        "    ax=ax,\n",
        "    zorder=4,\n",
        ")\n",
        "\n",
        "# 5. BALANCED AXIS TICK MARKERS (Spaced out for readability over a 1-year window)\n",
        "ax.xaxis.set_major_locator(mdates.MonthLocator()) # One tick per month\n",
        "ax.xaxis.set_major_formatter(mdates.DateFormatter(\"%b '%y\"))\n",
        "\n",
        "# Spacing Y-axis major ticks every 5 degrees instead of every 1 degree\n",
        "ax.yaxis.set_major_locator(ticker.MultipleLocator(5))\n",
        "ax.yaxis.set_minor_locator(ticker.MultipleLocator(1))\n",
        "\n",
        "# 6. Balanced Gridlines (High-contrast for major, faint/dotted for minor)\n",
        "ax.grid(True, which=\"major\", color=\"#e2e8f0\", linestyle=\"-\", linewidth=1.0)\n",
        "ax.grid(True, which=\"minor\", color=\"#f1f5f9\", linestyle=\":\", linewidth=0.5)\n",
        "ax.set_axisbelow(True)  # Keeps gridlines behind your data\n",
        "\n",
        "# 7. Final polishing\n",
        "plt.title(\n",
        "    \"London 2021 Historical Temperature Profile & Moving Average\",\n",
        "    fontsize=14,\n",
        "    fontweight=\"bold\",\n",
        "    pad=15\n",
        ")\n",
        "plt.xlabel(\"Timeline\", fontsize=11, labelpad=10)\n",
        "plt.ylabel(\"Temperature (°C)\", fontsize=11, labelpad=10)\n",
        "\n",
        "plt.xticks(rotation=0, ha='center', fontsize=10) # 0 rotation works beautifully now with monthly spacing\n",
        "plt.yticks(fontsize=10)\n",
        "plt.legend(loc=\"upper right\", frameon=True, facecolor='white', edgecolor='none')\n",
        "plt.xlim(df[\"time\"].min(), df[\"time\"].max())\n",
        "plt.tight_layout()\n",
        "\n",
        "# 8. Show the graph\n",
        "plt.show()"
